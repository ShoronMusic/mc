# 洋楽AIチャット - 環境変数例（.env.local にコピーして値を設定）
#
# 分離しないアーティスト名・Music8 検索の別名は環境変数ではなく JSON で編集する:
#   src/config/artist-compound-extra.json
#   src/config/music8-main-artist-aliases.json
# 手順は src/config/README.md を参照（編集後は再ビルド／再デプロイ）。

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ローカルで Google 認証したのに本番 (Site URL) に ?code= で飛ぶとき:
# 1) Supabase Redirect URLs に http://localhost:3002/auth/callback を入れる（127.0.0.1 で開いているなら http://127.0.0.1:3002/auth/callback も別途追加）
# OAuth の redirectTo は常に「いま開いているページのオリジン」を使う（NEXT_PUBLIC_APP_ORIGIN は参照しない）
# Google 認証: Dashboard → Authentication → URL Configuration
# Redirect URLs に次を両方入れること:
#   http://localhost:3002/auth/callback   （ローカル npm run dev。無いと Google 後に本番 Site URL へ ?code= で飛ぶことがある）
#   https://<本番ドメイン>/auth/callback
# 未登録だと ?code= がトップに付いたままログインできない（アプリ側ミドルウェア・インライン script で救済も可能）。
# マイページの「アカウントを削除」でDBから完全削除する場合に必要（サーバー専用・公開しないこと）
# SUPABASE_SERVICE_ROLE_KEY=
# 管理画面 /admin と /api/admin/* の利用者（Supabase Auth のユーザー UUID をカンマ区切り）。未設定なら /admin は誰も開けない
# 視聴履歴スタイル変更の「管理者のみ」制限にも同じリストを使用（未設定ならスタイルは誰でも変更可）
# STYLE_ADMIN_USER_IDS=
# comment-pack 行を「NG（DBから外す）」できる最高管理者（Supabase Auth のユーザー UUID をカンマ区切り）。未設定なら誰にも NG ボタンは出ない
# AI_TIDBIT_MODERATOR_USER_IDS=
# 上記に加え、ログイン email でも許可（小文字比較・カンマ区切り）。Route Handler では getSession が空になりがちなため getUser を使うが、UUID の設定も推奨
# AI_TIDBIT_MODERATOR_EMAILS=
# 上記 NG で song_tidbits を更新するとき、RLS を避けるには SERVICE_ROLE 推奨（未設定時はセッション用クライアントのみ）

# Google Gemini API
GEMINI_API_KEY=
# 1 にすると各 Gemini 呼び出しのトークン数をサーバーログに JSON 1行で出力（料金試算・集計用）
# GEMINI_LOG_USAGE=1
# SUPABASE_SERVICE_ROLE_KEY + gemini_usage_logs テーブルで DB に保存（/admin/gemini-usage）。0 で保存停止
# GEMINI_USAGE_PERSIST=
# 1 にすると同じ動画でも常に comment-pack を AI 新規生成（DB 再利用をオフ）
# COMMENT_PACK_SKIP_CACHE=
# 邦楽っぽいメタデータ（日本語文字・音声言語 ja）のときは基本コメント1本のみ（自由3本を生成せず料金削減）。0 で常に基本＋自由3本
# COMMENT_PACK_JP_ECONOMY=1
# 1 にすると「アーティストがメタで信頼できない」判定をオフにし、従来どおり曲解説・comment-pack を生成する
# AI_COMMENTARY_ALLOW_UNCERTAIN_ARTIST=
# MusicBrainz API（非商用無料）でアーティストの出身/活動地域が日本なら邦楽節約に含める。未設定なら呼び出ししない（User-Agent 必須・公式要件）
# https://musicbrainz.org/doc/MusicBrainz_API
# MUSICBRAINZ_USER_AGENT=musicaichat/0.1.0 ( https://あなたのサイトURL )
# 1 にすると MusicBrainz を使わない（日本語メタ判定のみ）
# MUSICBRAINZ_LOOKUP=0
# 1 にすると「チャンネルと一致しない A - B」向けの録音検索（順序補正）だけオフ。未設定なら USER_AGENT があるときだけ曖昧時に実行
# MUSICBRAINZ_TITLE_ORDER=0
# 邦楽でも、ONE OK ROCK / XG / Ado / ATARASHII GAKKO!（＋88rising）/ YOASOBI の公式 YouTube チャンネル（コード内の UC 固定）上の動画は AI を許可。それ以外の公式チャンネルを足すときは UC… をカンマ区切り
# JP_DOMESTIC_OFFICIAL_CHANNEL_EXCEPTION_IDS=

# YouTube Data API v3（「この曲を貼って」でAIが曲を検索して貼る機能用。未設定ならその機能は無効）
YOUTUBE_API_KEY=

# Ably（同期再生・チャット用。未設定でも起動可・同期は無効）
NEXT_PUBLIC_ABLY_API_KEY=

# Socket.io を使う場合（別サーバーで起動）
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Google Analytics 4（G-XXXXXXXXXX 形式）。未設定なら読み込まない
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 詳細フィードバックのメール送信先（Resend）。未設定ならDB保存のみでメールは送らない
# RESEND_API_KEY=
# 送信元アドレス（Resend で検証済みのドメイン推奨）。未設定時は onboarding@resend.dev
# RESEND_FROM=
# 通知メールの宛先（任意）。未設定時は reeshoron@gmail.com
# FEEDBACK_TO_EMAIL=

# トラブルシュート: 詳細フィードバック（モーダル送信）だけがメール対象。Good/悪いのみではメールしません。
# 本番（Vercel 等）では RESEND_API_KEY を環境変数に入れ、デプロイ後に再デプロイ。迷惑メールフォルダも確認。
